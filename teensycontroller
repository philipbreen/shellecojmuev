#include <Arduino.h>
#include <Wire.h>

#define SIGNAL_PIN A0

const uint8_t ARDUINO_ADDR = 8;

// ---------- SENSOR CONFIG ----------
const int oversamples = 4096;
float vref = 3.3;

// ---------- SAFETY ----------
const float MAX_AMPS = 25.0;
const unsigned long UNSAFE_DURATION = 333;

unsigned long overLimitStart = 0;
bool isOverLimit = false;
bool isUnsafe = false;

// ---------- DATA PACKET ----------
struct __attribute__((packed)) DataPacket {
  float amps;
  uint8_t unsafe;
};

// ---------- FUNCTION DECLARATIONS ----------
float readCurrent();
void updateSafety(float amps);
uint8_t sendPacket(float amps, uint8_t unsafeFlag);
void debugPrint(float amps, uint8_t unsafeFlag, uint8_t result);

// ---------- SETUP ----------
void setup() {
  Serial.begin(115200);
  Wire.begin();
  Wire.setClock(100000);

  analogReadResolution(12);
}

// ---------- LOOP ----------
void loop() {
  float amps = readCurrent();

// ---------- HARD ERROR CHECK ----------
bool errorState = false;

if (amps > 70.0) {
  errorState = true;
  isUnsafe = false; // force safe
}


if (!errorState) {
  updateSafety(amps);
}

uint8_t unsafeFlag = isUnsafe ? 1 : 0;
uint8_t result = sendPacket(errorState ? -1.0 : amps, unsafeFlag);

debugPrint(errorState ? -1.0 : amps, unsafeFlag, result);
  delay(100);
}

// ---------- CURRENT CALCULATION ----------
float readCurrent() {
  long total = 0;

  for (int i = 0; i < oversamples; i++) {
    total += analogRead(SIGNAL_PIN);
  }

  float avg = total / (float)oversamples;

  float voltage = avg * vref / 4095.0;
  float mv = voltage * 1000.0 + 2;  // offset
  float amps = mv;                  // 1 mV = 1 A

  return amps;
}

// ---------- SAFETY LOGIC ----------
void updateSafety(float amps) {
  unsigned long now = millis();

  if (amps > MAX_AMPS) {
    if (!isOverLimit) {
      overLimitStart = now;
      isOverLimit = true;
    }

    isUnsafe = (now - overLimitStart >= UNSAFE_DURATION);
  } else {
    isOverLimit = false;
    isUnsafe = false;
  }
}

// ---------- I2C SEND ----------
uint8_t sendPacket(float amps, uint8_t unsafeFlag) {
  DataPacket packet;
  packet.amps = amps;
  packet.unsafe = unsafeFlag;

  Wire.beginTransmission(ARDUINO_ADDR);
  Wire.write((uint8_t*)&packet, sizeof(packet));
  return Wire.endTransmission();
}

// ---------- DEBUG ----------
void debugPrint(float amps, uint8_t unsafeFlag, uint8_t result) {
  Serial.print("Amps: ");
if (amps < 0) {
  Serial.print("ERR");
} else {
  Serial.print(amps, 1);
}Serial.print(" | Unsafe: ");
  Serial.print(unsafeFlag ? "TRUE" : "FALSE");
  Serial.print(" | I2C: ");
  Serial.println(result);
}
